# ─── nu3go API — Environment Configuration ─────────────────────────────────
# Copy this file to .env.development (local) or .env.production (deploy)

NODE_ENV=development
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nu3go:your_password@localhost:5432/nu3go

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS / Frontend URL ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_NAME=nu3go
FROM_EMAIL=noreply@nu3go.lk
