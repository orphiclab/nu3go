{
    "name": "nu3go-api",
    "version": "0.1.0",
    "description": "nu3go Subscription Management API",
    "author": "nu3go",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "npm run migration:prod && node scripts/seed-admin.js && node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "migration:dev": "typeorm migration:run -d src/database/typeorm.config.ts",
        "migration:generate": "typeorm migration:generate -d src/database/typeorm.config.ts",
        "migration:prod": "typeorm migration:run -d dist/database/typeorm.config.js",
        "seed:admin": "npx ts-node -r tsconfig-paths/register scripts/seed-admin.ts"
    },
    "dependencies": {
        "@nestjs/common": "^10.4.5",
        "@nestjs/core": "^10.4.5",
        "@nestjs/platform-express": "^10.4.5",
        "@nestjs/config": "^3.3.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/schedule": "^4.1.2",
        "@nestjs/swagger": "^8.1.0",
        "@nestjs/throttler": "^6.2.1",
        "@nestjs/typeorm": "^10.0.2",
        "typeorm": "^0.3.20",
        "pg": "^8.13.1",
        "redis": "^4.7.0",
        "ioredis": "^5.4.1",
        "@nestjs-modules/ioredis": "^2.0.2",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "bcryptjs": "^2.4.3",
        "class-validator": "^0.14.1",
        "class-transformer": "^0.5.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "uuid": "^10.0.0",
        "jsonwebtoken": "^9.0.2",
        "exceljs": "^4.4.0",
        "pdfkit": "^0.15.0",
        "nodemailer": "^6.9.16",
        "qrcode": "^1.5.4",
        "winston": "^3.15.0",
        "nest-winston": "^1.10.0",
        "axios": "^1.7.9",
        "date-fns": "^4.1.0"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.5",
        "@nestjs/schematics": "^10.2.3",
        "@nestjs/testing": "^10.4.5",
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.0.0",
        "@types/nodemailer": "^6.4.16",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/pdfkit": "^0.13.5",
        "@types/qrcode": "^1.5.5",
        "@types/uuid": "^10.0.0",
        "eslint": "^8.57.1",
        "jest": "^29.7.0",
        "prettier": "^3.3.3",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}